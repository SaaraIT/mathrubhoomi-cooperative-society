<%= render 'shared/admin_sidebar' %>

<div class="main-content">
  <div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Edit Requests</h2>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
      <div class="card-body">
        <%= form_tag admin_edit_requests_path, method: :get, class: "row g-3" do %>
          <div class="col-md-3">
            <label class="form-label">Filter by Branch</label>
            <%= select_tag :branch_id,
                options_from_collection_for_select(@branches, :id, :name, params[:branch_id]),
                include_blank: "All Branches",
                class: "form-select" %>
          </div>
          <div class="col-md-3">
            <label class="form-label">Filter by Resource Type</label>
            <%= select_tag :resource_type,
                options_for_select(
                  EditRequest::RESOURCE_TYPES.map { |t| [t.underscore.humanize.titleize, t] },
                  params[:resource_type]
                ),
                include_blank: "All Types",
                class: "form-select" %>
          </div>
          <div class="col-md-3">
            <label class="form-label">Filter by Status</label>
            <%= select_tag :status,
                options_for_select([["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"]], params[:status]),
                class: "form-select" %>
          </div>
          <div class="col-md-3 d-flex align-items-end">
            <%= submit_tag "Filter", class: "btn btn-primary me-2" %>
            <%= link_to "Clear", admin_edit_requests_path, class: "btn btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Edit Requests Table -->
    <div class="card">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>ID</th>
                <th>Resource Type</th>
                <th>Resource</th>
                <th>Requested By</th>
                <th>Branch</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Requested On</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @edit_requests.any? %>
                <% @edit_requests.each do |request| %>
                  <tr>
                    <td><%= request.id %></td>
                    <td><%= request.resource_type_display %></td>
                    <td>
                      <% resource = request.resource %>
                      <% if resource %>
                        <% case request.resource_type %>
                        <% when 'Member' %>
                          <%= link_to "#{resource.name} (##{request.resource_id})", member_path(resource), target: "_blank" %>
                        <% when 'LoanApplication' %>
                          <%= link_to "##{request.resource_id}", member_loan_application_path(resource.member, resource), target: "_blank" %>
                        <% when 'JewelLoan' %>
                          <%= link_to "##{request.resource_id}", member_jewel_loan_path(resource.member, resource), target: "_blank" %>
                        <% when 'ShgLoanApplication' %>
                          <%= link_to "##{request.resource_id}", shg_loan_application_path(resource), target: "_blank" %>
                        <% else %>
                          #<%= request.resource_id %>
                        <% end %>
                      <% else %>
                        #<%= request.resource_id %> (deleted)
                      <% end %>
                    </td>
                    <td><%= request.user&.email %></td>
                    <td><%= request.cooperative_branch&.name %></td>
                    <td>
                      <span class="text-truncate d-inline-block" style="max-width: 200px;" title="<%= request.reason %>">
                        <%= truncate(request.reason, length: 50) %>
                      </span>
                    </td>
                    <td>
                      <% case request.status %>
                      <% when "pending" %>
                        <span class="badge bg-warning text-dark">Pending</span>
                      <% when "approved" %>
                        <span class="badge bg-success">Approved</span>
                        <br><small class="text-muted">by <%= request.approved_by&.email %></small>
                      <% when "rejected" %>
                        <span class="badge bg-danger">Rejected</span>
                        <br><small class="text-muted">by <%= request.approved_by&.email %></small>
                        <% if request.rejection_reason.present? %>
                          <br><small class="text-muted"><%= truncate(request.rejection_reason, length: 30) %></small>
                        <% end %>
                      <% end %>
                    </td>
                    <td><%= request.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                    <td>
                      <% if request.status == "pending" %>
                        <div class="btn-group btn-group-sm">
                          <%= button_to "Approve", admin_approve_edit_request_path(request),
                              method: :patch,
                              class: "btn btn-success btn-sm",
                              data: { confirm: "Are you sure you want to approve this edit request?" } %>

                          <button type="button" class="btn btn-danger btn-sm"
                                  data-bs-toggle="modal"
                                  data-bs-target="#rejectModal<%= request.id %>">
                            Reject
                          </button>
                        </div>

                        <!-- Reject Modal -->
                        <div class="modal fade" id="rejectModal<%= request.id %>" tabindex="-1">
                          <div class="modal-dialog">
                            <div class="modal-content">
                              <%= form_tag admin_reject_edit_request_path(request), method: :patch do %>
                                <div class="modal-header">
                                  <h5 class="modal-title">Reject Edit Request</h5>
                                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                  <div class="mb-3">
                                    <label class="form-label">Rejection Reason (Optional)</label>
                                    <%= text_area_tag :rejection_reason, nil, class: "form-control", rows: 3, placeholder: "Provide a reason for rejection..." %>
                                  </div>
                                </div>
                                <div class="modal-footer">
                                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                  <%= submit_tag "Reject Request", class: "btn btn-danger" %>
                                </div>
                              <% end %>
                            </div>
                          </div>
                        </div>
                      <% else %>
                        <span class="text-muted">-</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="9" class="text-center text-muted py-4">
                    No edit requests found.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
