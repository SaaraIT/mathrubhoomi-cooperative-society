<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <h1 class="h2">Edit User: <%= @user.email %></h1>
      <%= link_to "Back to Users", admin_users_path, class: "btn btn-outline-secondary mb-3" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body">
          <%= form_with model: @user, url: admin_update_user_path(@user), method: :patch, local: true do |form| %>
            <% if @user.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :email, class: "form-label" %>
              <%= form.email_field :email, class: "form-control", required: true %>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :password, "New Password (leave blank to keep current)", class: "form-label" %>
                  <%= form.password_field :password, class: "form-control" %>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :password_confirmation, class: "form-label" %>
                  <%= form.password_field :password_confirmation, class: "form-control" %>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :role, class: "form-label" %>
                  <%= form.select :role,
                      options_for_select([
                        ['Staff', 'staff'],
                        ['Manager', 'manager'],
                        ['Section Head (Head Office)', 'section_head'],
                        ['Super Admin', 'super_admin']
                      ], @user.role),
                      {},
                      { class: "form-select", id: "user_role" } %>
                </div>
              </div>
              <div class="col-md-6" id="branch_field">
                <div class="mb-3">
                  <%= form.label :cooperative_branch_id, "Branch", class: "form-label" %>
                  <%= form.select :cooperative_branch_id,
                      options_from_collection_for_select(@branches, :id, :name, @user.cooperative_branch_id),
                      { prompt: 'Select Branch' },
                      { class: "form-select", id: "user_branch" } %>
                </div>
              </div>
            </div>

            <div class="alert alert-info small" id="head_office_note" style="display: none;">
              <strong>Note:</strong> Super Admin and Section Head users belong to Head Office and don't require a branch assignment.
            </div>

            <div class="d-grid">
              <%= form.submit "Update User", class: "btn btn-success" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const roleSelect = document.getElementById('user_role');
  const branchField = document.getElementById('branch_field');
  const branchSelect = document.getElementById('user_branch');
  const headOfficeNote = document.getElementById('head_office_note');

  function toggleBranchField() {
    const selectedRole = roleSelect.value;
    if (selectedRole === 'super_admin' || selectedRole === 'section_head') {
      branchField.style.display = 'none';
      branchSelect.removeAttribute('required');
      headOfficeNote.style.display = 'block';
    } else {
      branchField.style.display = 'block';
      branchSelect.setAttribute('required', 'required');
      headOfficeNote.style.display = 'none';
    }
  }

  roleSelect.addEventListener('change', toggleBranchField);
  toggleBranchField(); // Run on page load
});
</script>
