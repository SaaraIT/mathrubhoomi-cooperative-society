<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Loan Purposes</h1>
        <%= link_to "Add New Loan Purpose", admin_new_loan_purpose_path, class: "btn btn-success" %>
      </div>
    </div>
  </div>

  <div class="row mb-2">
    <div class="col-12 text-end">
      <span class="text-muted">Total: <%= @loan_purposes.count %> loan purposes configured</span>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Description</th>
                  <th>Applications</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @loan_purposes.each do |loan_purpose| %>
                  <tr class="<%= 'table-secondary' unless loan_purpose.active? %>">
                    <td><strong><%= loan_purpose.name %></strong></td>
                    <td><%= truncate(loan_purpose.description, length: 80) if loan_purpose.description.present? %></td>
                    <td><span class="badge bg-info"><%= loan_purpose.loan_applications.count %></span></td>
                    <td>
                      <% if loan_purpose.active? %>
                        <span class="badge bg-success">Active</span>
                      <% else %>
                        <span class="badge bg-danger">Inactive</span>
                      <% end %>
                    </td>
                    <td><%= loan_purpose.created_at.strftime("%d %b %Y") %></td>
                    <td>
                      <%= link_to "Edit", admin_edit_loan_purpose_path(loan_purpose), class: "btn btn-sm btn-outline-secondary" %>
                      <% if loan_purpose.active? %>
                        <%= link_to "Deactivate",
                            admin_toggle_loan_purpose_path(loan_purpose),
                            method: :patch,
                            data: { confirm: "Are you sure you want to deactivate this loan purpose?" },
                            class: "btn btn-sm btn-outline-warning" %>
                      <% else %>
                        <%= link_to "Activate",
                            admin_toggle_loan_purpose_path(loan_purpose),
                            method: :patch,
                            class: "btn btn-sm btn-outline-success" %>
                      <% end %>
                      <%= link_to "Delete",
                          admin_destroy_loan_purpose_path(loan_purpose),
                          method: :delete,
                          data: { confirm: "Are you sure you want to delete this loan purpose?" },
                          class: "btn btn-sm btn-outline-danger" %>
                    </td>
                  </tr>
                <% end %>

                <% if @loan_purposes.empty? %>
                  <tr>
                    <td colspan="6" class="text-center py-4">
                      <p class="text-muted mb-2">No loan purposes configured yet.</p>
                      <%= link_to "Add First Loan Purpose", admin_new_loan_purpose_path, class: "btn btn-success" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
