<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <h1 class="h2">Add New Loan Purpose</h1>
      <%= link_to "Back to Loan Purposes", admin_loan_purposes_path, class: "btn btn-outline-secondary mb-3" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-8">
      <div class="card">
        <div class="card-body">
          <%= form_with model: @loan_purpose, url: admin_create_loan_purpose_path, local: true do |form| %>
            <% if @loan_purpose.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @loan_purpose.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, "Purpose Name", class: "form-label" %>
              <%= form.text_field :name, class: "form-control", required: true, placeholder: "e.g., House Construction" %>
            </div>

            <div class="mb-3">
              <%= form.label :description, "Description", class: "form-label" %>
              <%= form.text_area :description, class: "form-control", rows: 3, placeholder: "Optional description of this loan purpose" %>
            </div>

            <div class="mb-3">
              <div class="form-check">
                <%= form.check_box :active, class: "form-check-input", checked: true %>
                <%= form.label :active, "Active", class: "form-check-label" %>
              </div>
            </div>

            <div class="d-grid">
              <%= form.submit "Create Loan Purpose", class: "btn btn-success" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Help</h5>
        </div>
        <div class="card-body">
          <p><strong>Name:</strong> The purpose for which the loan is being taken.</p>
          <p><strong>Description:</strong> Optional additional details about this purpose.</p>
          <p class="mb-0"><strong>Active:</strong> Only active purposes will appear in dropdown selections.</p>
        </div>
      </div>
    </div>
  </div>
</div>
