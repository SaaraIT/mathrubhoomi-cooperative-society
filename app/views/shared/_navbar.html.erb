<header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0">
  <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3" href="#"><%= image_tag "logo.png", style: "width: 35px; margin-right: 15px" %> MATHRUBHOOMI SOUHARDA SAHAKARI SANGHA LTD - <%= Current.branch.try(:name) %></a>
  <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>
  
  <div class="d-flex ms-auto">
    <div class="nav-item text-nowrap">
      <% unless Current.branch.blank? %>
        <%= link_to edit_cooperative_branch_path(Current.branch), class: "nav-link px-3 text-white d-flex align-items-center" do %>
          <span data-feather="briefcase" class="me-2"></span>
          Branch Details
        <% end %>
      <%end%>
    </div>
    <div class="nav-item text-nowrap">
      <%= link_to destroy_user_session_path, method: :delete, class: "nav-link px-3 text-white d-flex align-items-center" do %>
        <span data-feather="log-out" class="me-2"></span>
        Sign out
      <% end %>
    </div>
  </div>
</header>