<style>
  body {
    font-family: Arial, sans-serif;
    text-align: justify;
  }

  h1, h2, h3 {
    text-align: center;
  }

  .section {
    margin-bottom: 20px;
  }

  .signature-box {
    margin-top: 20px;
  }

  .underline {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 0.2em;
  }

  .signature-box div {
    border: 1px solid black;
    width: 100px;
    height: 100px;
    text-align: center;
    line-height: 50px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  td {
    padding: 8px;
  }

  .right-align {
    text-align: right;
  }

  .table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  .table td, .table th {
    border: 1px solid #aaa;
    padding: 6px;
    vertical-align: top;
  }

  .readonly-field {
    background-color: #f5f5f5;
    border: 1px solid #ddd;
    padding: 8px;
    display: inline-block;
    min-width: 100px;
  }
</style>

<%= form_with model: [@member, @loan_application, @demand_promissory_note] do |f| %>
  <% if @demand_promissory_note.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @demand_promissory_note.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="container">
    <table>
      <tr>
        <td><strong>Branch:</strong> <%= Current.branch.try(:name) %></td>
        <td class="right-align">
          <strong>Loan No.:</strong> <%= f.text_field :loan_no, placeholder: "Enter Loan No.", required: true %>
        </td>
      </tr>
    </table>

    <h3><u>DEMAND PROMISSORY NOTE</u></h3>

    <p>On demand We the members of the Shg: <span class="readonly-field"><%= @loan_application.self_help_group.name %></span></p>
    Address: <span class="readonly-field"><%= @loan_application.self_help_group.address %></span>

    <p>Do hereby promise to pay Mathrubhoomi Souharda Sahakari Sangha Ltd. Or Order a sum
of <span class="readonly-field"><%= number_with_precision(@loan_application.sanction_amount, precision: 2) %></span> Rupees ____ only</p>

    <p>along with the interest thereon at <span class="readonly-field"><%= @loan_application.int_rate %></span> p.a. for value received on this <span class="readonly-field"><%= @demand_promissory_note.day %></span> day of <span class="readonly-field"><%= @demand_promissory_note.month %></span> <span class="readonly-field"><%= @demand_promissory_note.year %></span>.</p>

    <hr>
    <table class="table">
      <thead>
        <tr>
          <th style="width: 100px">ಕ್ರ.ಸಂ./Si.No</th>
          <th style="width: 500px">ಹೆಸರು/Name</th>
          <th>ಆಧಾರ್ ಸಂಖ್ಯೆ/Aadhar Number</th>
          <th>ಸಹಿ/Signature</th>
        </tr>
      </thead>
      <tbody>
        <% @loan_application.self_help_group.shg_members.each_with_index do |member, index| %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= member.name %></td>
            <td><%= member.aadhar_number %></td>
            <td></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <br /><br />

    <table class="footer" style="width: 100%;">
      <tr>
        <td class="signature">_______________</td>
        <td class="signature" style="text-align: right">_______________</td>
      </tr>
      <tr>
        <td class="signature">ಪ್ರಧಾನಕರು / President</td>
        <td class="signature" style="text-align: right">ಸಂಯೋಜಕರು / Secretary</td>
      </tr>
    </table>

    <div style="margin-top: 20px;">
      <%= f.submit "Save", class: "btn btn-primary" %>
    </div>
    <br />
  </div>
<% end %>
